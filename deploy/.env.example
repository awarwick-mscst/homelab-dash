# Homelab Dashboard Configuration

# Security - CHANGE THIS! Generate with: openssl rand -hex 32
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32

# Database
DATABASE_URL=sqlite+aiosqlite:///./homelab.db

# JWT
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Proxmox (optional)
PROXMOX_HOST=
PROXMOX_TOKEN_ID=
PROXMOX_TOKEN_SECRET=
PROXMOX_VERIFY_SSL=false

# pfSense (optional)
PFSENSE_HOST=
PFSENSE_API_KEY=
PFSENSE_API_SECRET=
PFSENSE_VERIFY_SSL=false

# Scanning
NMAP_PATH=/usr/bin/nmap

# Background tasks
HEALTH_CHECK_INTERVAL=60
PROXMOX_POLL_INTERVAL=120
